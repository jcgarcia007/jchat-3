{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/icon/**",
              "components/place/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:SF Pro Text|SF Pro Display))/i]",
        "message": "Font not provided by the design system. Available: SF Pro Text, SF Pro Display."
      },
      {
        "selector": "JSXOpeningElement[name.name='ActivityBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:height|labels|lowLabel|highLabel|onDark|style|key|ref|className|style|children)$/]",
        "message": "<ActivityBar> doesn't accept that prop. Declared props: height, labels, lowLabel, highLabel, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|emoji|src|size|color|square|online|verified|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, emoji, src, size, color, square, online, verified, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|color|dot|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, color, dot, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:blue|green|teal|success|warning|danger|purple|neutral)$/]",
        "message": "<Badge> tone must be one of 'blue' | 'green' | 'teal' | 'success' | 'warning' | 'danger' | 'purple' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|block|disabled|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, block, disabled, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gradient|secondary|soft|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gradient' | 'secondary' | 'soft' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tint|pad|radius|shadow|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, tint, pad, radius, shadow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tint'] > Literal[value!=/^(?:none|blue|grey|green)$/]",
        "message": "<Card> tint must be one of 'none' | 'blue' | 'grey' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|showEmoji|style|key|ref|className|style|children)$/]",
        "message": "<CategoryPill> doesn't accept that prop. Declared props: category, showEmoji, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='CategoryPill'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:Bar|Cafe|Restaurant|Gym|Beauty|Retail|Entertainment|Hotel|Health|Other)$/]",
        "message": "<CategoryPill> category must be one of 'Bar' | 'Cafe' | 'Restaurant' | 'Gym' | 'Beauty' | 'Retail' | 'Entertainment' | 'Hotel' | 'Health' | 'Other'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: children, active, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|stroke|color|style|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, stroke, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|type|right|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, value, onChange, placeholder, type, right, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|emoji|category|activity|activeCount|rank|top|onClick|style|key|ref|className|style|children)$/]",
        "message": "<PlaceRow> doesn't accept that prop. Declared props: name, emoji, category, activity, activeCount, rank, top, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceRow'] > JSXAttribute[name.name='category'] > Literal[value!=/^(?:Bar|Cafe|Restaurant|Gym|Beauty|Retail|Entertainment|Hotel|Health|Other)$/]",
        "message": "<PlaceRow> category must be one of 'Bar' | 'Cafe' | 'Restaurant' | 'Gym' | 'Beauty' | 'Retail' | 'Entertainment' | 'Hotel' | 'Health' | 'Other'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlaceRow'] > JSXAttribute[name.name='activity'] > Literal[value!=/^(?:Low|Medium|High|Trending)$/]",
        "message": "<PlaceRow> activity must be one of 'Low' | 'Medium' | 'High' | 'Trending'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
