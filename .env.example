# JChat 3.0 — Environment variables (Task 0.1)
# Copy to `.env` and fill in real values. NEVER commit `.env`.
#
# Canonical keys (per Dev Plan Task 0.1):
SUPABASE_URL=
SUPABASE_ANON_KEY=
STRIPE_PK=
GOOGLE_MAPS_KEY=

# ── Mobile (Expo) — must be EXPO_PUBLIC_ prefixed to be readable client-side ──
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_STRIPE_PK=
EXPO_PUBLIC_GOOGLE_MAPS_KEY=

# ── Web (Next.js) — must be NEXT_PUBLIC_ prefixed to be readable client-side ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_STRIPE_PK=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Server-side only (Edge Functions) — NEVER expose to the client ──
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
